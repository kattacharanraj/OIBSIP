# Copy this file to ".env" and fill in your own values.

# Server port
PORT=5000

# MongoDB connection string
# Local MongoDB:  mongodb://127.0.0.1:27017/pizzaapp
# MongoDB Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/pizzaapp
MONGO_URI=mongodb://127.0.0.1:27017/pizzaapp

# Secret used to sign login tokens (put any random long text here)
JWT_SECRET=change_this_to_a_long_random_secret

# Where the frontend runs (used to build email links)
CLIENT_URL=http://localhost:5173

# The default admin account that gets created automatically
ADMIN_EMAIL=admin@pizza.com
ADMIN_PASSWORD=admin123

# Email settings (OPTIONAL).
# If you leave these blank, the app still works: verification / reset links
# are printed in the server console instead of being emailed.
# For Gmail, use an "App Password" (not your normal password).
EMAIL_USER=
EMAIL_PASS=
